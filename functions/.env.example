# ========================
# PostgreSQL Configuration
# ========================
# Option 1: Individual parameters
PGHOST=your-cloud-sql-host
PGPORT=5432
PGUSER=your-db-user
PGPASSWORD=your-db-password
PGDATABASE=logixius_db

# Option 2: Connection string (overrides individual params if set)
# DATABASE_URL=postgresql://user:password@host:5432/logixius_db?sslmode=require

# ========================
# Session Secret
# ========================
SESSION_SECRET=your-random-secret-key-here

# ========================
# Firebase Storage
# ========================
# The Firebase Storage bucket name (usually your-project-id.appspot.com)
STORAGE_BUCKET=your-project-id.appspot.com

# ========================
# Server
# ========================
PORT=3000
