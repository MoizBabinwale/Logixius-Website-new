rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for certificates and offer letters
    match /certificates/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /offer-letters/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
